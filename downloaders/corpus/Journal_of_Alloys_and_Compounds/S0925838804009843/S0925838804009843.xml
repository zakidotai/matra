<ce:title>Production of Fe–Ti–Si alloys from the ilmenite ore and their magnetic properties</ce:title>
<ce:author-group>
<ce:author>
<ce:given-name>Tetsuji</ce:given-name>
<ce:surname>Saito</ce:surname>
<ce:cross-ref refid="cor1">*</ce:cross-ref>
</ce:author>
